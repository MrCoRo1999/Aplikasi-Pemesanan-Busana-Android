<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:orientation="vertical"
    android:background="@drawable/bg_nav_header"
    android:gravity="bottom"
    android:padding="20dp"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Logo Icon App -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Logo Tengah -->
        <TextView
            android:id="@+id/logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/eastman_roman_trial_extrabold"
            android:text="FAZERMOOD"
            android:textColor="@color/colorPrimary"
            android:textSize="@dimen/size_28" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">


        </LinearLayout>
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="12dp" />

    <!-- Optional: Email/User Info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Support?"
        android:textSize="12sp"
        android:textColor="@color/black"/>

    <TextView
        android:id="@+id/tvWa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WhatsApp : 08812860980"
        android:textColor="@color/black"
        android:textSize="12sp"/>

</LinearLayout>
