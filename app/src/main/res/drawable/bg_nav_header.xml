<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradasi Teal ke Beige -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/teal_500"
                android:endColor="@color/beige_500"
                android:angle="135" />
        </shape>
    </item>

    <!-- Lapisan transparansi lembut di atas gradasi -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white_50" />
        </shape>
    </item>
</layer-list>
